{
  "manifest_version": 3,
  "name": "Jellyfin Checker",
  "version": "0.7.1",
  "author": "patientone",
  "description": "Check if movies, shows, or people are available on your Jellyfin server",
  "permissions": [
    "storage",
    "activeTab",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.imdb.com/title/*",
        "https://www.imdb.com/name/*",
        "https://imdb.com/title/*",
        "https://imdb.com/name/*",
        "https://m.imdb.com/title/*",
        "https://m.imdb.com/name/*",
        "https://www.filmweb.pl/film/*",
        "https://www.filmweb.pl/serial/*",
        "https://www.filmweb.pl/person/*",
        "https://filmweb.pl/film/*",
        "https://filmweb.pl/serial/*",
        "https://filmweb.pl/person/*",
        "https://www.themoviedb.org/movie/*",
        "https://www.themoviedb.org/tv/*",
        "https://www.themoviedb.org/person/*",
        "https://themoviedb.org/movie/*",
        "https://themoviedb.org/tv/*",
        "https://themoviedb.org/person/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
